# Firebase Admin SDK (server-side — required for API routes)
# Generate from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID="pportfolio-a820b"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@pportfolio-a820b.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Admin Password (Required for logging into the admin portal)
ADMIN_PASSWORD="your-secure-password"

# JWT Secret for admin session token
JWT_SECRET="generate-a-random-secret-key"
